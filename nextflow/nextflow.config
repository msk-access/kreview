manifest {
    name            = 'kreview'
    author          = 'MSK-ACCESS Team'
    homePage        = 'https://github.com/msk-access/kreview'
    description     = 'Evaluation Dashboard for Krewlyzer Fragmentomics Parameters'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=22.10.1'
    version         = '0.0.5'
}

params {
    // Required Inputs
    cancer_samplesheet      = null
    healthy_xs1_samplesheet = null
    healthy_xs2_samplesheet = null
    cbioportal_dir          = null
    krewlyzer_dir           = null
    
    // Output options
    outdir                  = './results'

    // ML Engine Tunables
    cv_folds                = 5
    impute_strategy         = 'median'
    chunk_size              = 50        // Defaults to 50 for local posix limits

    // Targeted Execution Filters
    features                = null      // E.g. "AtacOnTarget,FSCOnTarget"
    tier                    = null      // E.g. 1 or 2

    help = false
}

process {
    cpus   = 4
    memory = '16 GB'
    time   = '12h'
    container = 'ghcr.io/msk-access/kreview:latest'

    withLabel: 'process_high' {
        cpus   = 8
        memory = '32 GB'
        time   = '24h'
    }
}

profiles {
    docker {
        docker.enabled      = true
        docker.runOptions   = '-v /:/ -v /Users:/Users' // Grant absolute access for URI binding
        singularity.enabled = false
    }

    slurm {
        process {
            executor       = 'slurm'
            queue          = 'cmobic_cpu'
        }
        singularity {
            enabled    = true
            autoMounts = true  // Crucial for scanning 14K parquet directories
        }
        docker.enabled = false
        
        // HPC Optimization
        params.chunk_size = 500
    }
}

// Execution reporting logs
trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_trace.txt"
    overwrite = true
}
timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_timeline.html"
    overwrite = true
}
report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_report.html"
    overwrite = true
}
