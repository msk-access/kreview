manifest {
    name            = 'kreview'
    author          = 'MSK-ACCESS Team'
    homePage        = 'https://github.com/msk-access/kreview'
    description     = 'Evaluation Dashboard for Krewlyzer Fragmentomics Parameters'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=22.10.1'
    version         = '0.0.9'
}

params {
    // Required Inputs
    cancer_samplesheet      = null
    healthy_xs1_samplesheet = null
    healthy_xs2_samplesheet = null
    cbioportal_dir          = null
    krewlyzer_dir           = null
    
    // Output options
    outdir                  = './results'

    // Pipeline Mode
    // 'monolithic' — Single KREVIEW_RUN process (backward compatible, default)
    // 'multistage' — Decomposed: Label → Extract(×N) → Fuse → Eval → Report
    pipeline_mode           = 'monolithic'

    // ML Engine Tunables
    cv_folds                = 5
    top_percentile          = 10.0
    impute_strategy         = 'median'
    chunk_size              = 'auto'    // Dynamic: probes parquet row density at runtime

    // SHAP Explainability (visualization only — does not affect model accuracy)
    shap_samples            = 500       // Overridden to 5000 in slurm profile
    shap_features           = 10        // Overridden to 20 in slurm profile

    // Execution Control
    resume_eval             = false     // Skip evaluators with existing model results
    skip_report             = false     // Skip Quarto dashboard generation
    cvd_safe                = false     // Colorblind-safe palette
    compute_univariate_auc  = false     // Per-feature univariate LR AUC (~10s per evaluator)
    export_duckdb           = false     // Export consolidated DuckDB lake (high memory cost)
    ch_hotspot_maf          = null      // Optional CH hotspot MAF for CH-only demotion

    // Labeling Engine Tunables
    min_vaf                 = 0.01      // Min VAF for Possible ctDNA+ classification
    min_fragments           = 2000      // Min fragments PF — below → Insufficient Data
    min_variants            = 1         // Min # variants passing VAF for Possible ctDNA+

    // Targeted Execution Filters
    features                = null      // E.g. "AtacOnTarget,FSCOnTarget"
    tier                    = null      // E.g. 1 or 2

    // Multi-stage Pipeline Options (only used when pipeline_mode = 'multistage')
    run_gpu_eval            = false     // Enable KREVIEW_EVAL_GPU step
    gpu_models              = 'tabpfn,tabicl' // GPU foundation models
    gpu_device              = 'cuda'          // PyTorch device
    gpu_no_finetune         = false           // Use zero-shot (not recommended)
    gpu_finetune_epochs     = 30              // Fine-tuning epochs
    run_multimodal_eval     = false     // Enable KREVIEW_EVAL_MULTIMODAL step
    multimodal_models       = 'rf,xgb'        // Models for multimodal eval
    multimodal_top_k        = 50              // Top-K feature selection
    min_evaluators          = 1         // Min evaluators per sample for fuse filtering

    help = false

    // SLURM partition override (comma-separated for multi-partition scheduling)
    partition       = null
    gpu_partition   = null              // GPU partition for KREVIEW_EVAL_GPU

    // nf-core institutional config support
    custom_config_version = 'master'
    custom_config_base    = "https://raw.githubusercontent.com/nf-core/configs/${params.custom_config_version}"
}

process {
    cache  = 'lenient'  // GPFS/Spectrum Scale breaks default inode-based hashing; use name+size only
    cpus   = 4
    memory = '16 GB'
    time   = '12h'
    shell  = ['/bin/bash', '-euo', 'pipefail']
    container = "ghcr.io/msk-access/kreview:v${manifest.version}"
    clusterOptions = ''

    // ── Resource labels ──
    withLabel: 'process_medium' {
        cpus   = 4
        memory = { 32.GB * task.attempt }
        time   = { 2.h * task.attempt }
    }

    withLabel: 'process_high' {
        cpus   = 8
        memory = { 64.GB * task.attempt }
        time   = { 3.h * task.attempt }
    }

    withLabel: 'process_gpu' {
        cpus   = 4
        memory = { 32.GB * task.attempt }
        time   = { 2.h * task.attempt }
        // GPU scheduling — SLURM picks nodes with accelerators.
        // Uncomment when GPU containers are available:
        // accelerator 1, type: 'nvidia-tesla-*'
        // queue = params.gpu_partition ?: 'gpu'
    }

    // ── Per-process withName overrides ──
    // withName takes precedence over institutional configs' withLabel
    // overrides, ensuring kreview always gets the right resources.

    // Monolithic mode (backward compat)
    withName: 'KREVIEW_RUN' {
        cpus   = 8
        memory = { 64.GB * task.attempt }
        time   = { 3.h  * task.attempt }
    }

    // Multistage: labeling is lightweight (~30s, low memory)
    withName: 'KREVIEW_LABEL' {
        cpus   = 2
        memory = { 8.GB * task.attempt }
        time   = { 30.min * task.attempt }
    }

    // Multistage: per-evaluator extraction streams one chunk at a time
    // Memory profile: ~6GB per evaluator for DuckDB streaming
    withName: 'KREVIEW_EXTRACT' {
        cpus   = 4
        memory = { 16.GB * task.attempt }
        time   = { 1.h * task.attempt }
    }

    // Multistage: fuse is fast (in-memory pandas join)
    withName: 'KREVIEW_FUSE' {
        cpus   = 2
        memory = { 16.GB * task.attempt }
        time   = { 30.min * task.attempt }
    }

    // Multistage: CPU eval trains LR/RF/XGBoost across all evaluators
    withName: 'KREVIEW_EVAL_CPU' {
        cpus   = 8
        memory = { 64.GB * task.attempt }
        time   = { 3.h * task.attempt }
    }

    // Multistage: GPU eval on super-matrix
    withName: 'KREVIEW_EVAL_GPU' {
        cpus   = 4
        memory = { 32.GB * task.attempt }
        time   = { 2.h * task.attempt }
    }

    // Multistage: multimodal cross-evaluator analysis
    withName: 'KREVIEW_EVAL_MULTIMODAL' {
        cpus   = 8
        memory = { 64.GB * task.attempt }
        time   = { 3.h * task.attempt }
    }

    // Multistage: report rendering (Quarto + SHAP)
    withName: 'KREVIEW_REPORT' {
        cpus   = 4
        memory = { 32.GB * task.attempt }
        time   = { 2.h * task.attempt }
    }
}

// Load nf-core institutional configs (e.g. iris, jax, sanger, etc.)
// See: https://github.com/nf-core/configs
try {
    includeConfig "${params.custom_config_base}/nfcore_custom.config"
} catch (Exception e) {
    System.err.println("WARNING: Could not load nf-core/configs — institutional profiles unavailable")
}

profiles {
    docker {
        docker.enabled      = true
        docker.runOptions   = '-v /:/ -v /Users:/Users' // Grant absolute access for URI binding
        singularity.enabled = false
    }

    slurm {
        process {
            executor       = 'slurm'
            queue          = params.partition ?: 'cmobic_cpu'
        }
        singularity {
            enabled    = true
            autoMounts = true  // Crucial for scanning 14K parquet directories
        }
        docker.enabled = false
        
        // HPC Optimization — GPFS has no SFTP file descriptor limits
        params.chunk_size    = 'auto'  // Dynamic: probes row density (GPFS has no FD limits)
        params.cv_folds      = 10
        params.shap_samples  = 5000
        params.shap_features = 30
        params.resume_eval   = true
    }

    // IRIS HPC profile — works WITH nf-core iris institutional config
    // Sets params.partition so iris's dynamic queue closure routes to cmobic_cpu
    iris {
        // Override iris institutional config defaults
        params.partition = 'cmobic_cpu'

        process {
            executor       = 'slurm'
            cache          = 'lenient'   // iris config sets true; we need lenient for GPFS
        }
        singularity {
            enabled    = true
            autoMounts = true
            cacheDir   = "${HOME}/.singularity_cache"
            runOptions = '-B /data1'    // Bind /data1 for cbioportal + krewlyzer val paths
        }
        docker.enabled = false

        // HPC Optimization — GPFS has no SFTP file descriptor limits
        params.chunk_size    = 'auto'  // Dynamic: probes row density (GPFS has no FD limits)
        params.cv_folds      = 10
        params.shap_samples  = 5000
        params.shap_features = 30
        params.resume_eval   = true
    }
}

// Execution reporting logs
trace {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/execution_trace.txt"
    overwrite = true
    fields    = 'task_id,hash,native_id,process,tag,name,status,exit,module,container,cpus,time,disk,memory,attempt,submit,start,complete,duration,realtime,queue,%cpu,%mem,rss,vmem,peak_rss,peak_vmem,rchar,wchar,syscr,syscw,read_bytes,write_bytes'
}
timeline {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/execution_timeline.html"
    overwrite = true
}
report {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/execution_report.html"
    overwrite = true
}
dag {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/pipeline_dag.svg"
    overwrite = true
}
